{
  "manifest_version": 2,
  "name": "Yameen — Arabic RTL for AI",
  "short_name": "Yameen",
  "version": "1.2.0",
  "description": "Auto-detects Arabic text and fixes RTL direction. Works on 20+ AI and productivity platforms.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": ["storage", "activeTab"],
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://grok.com/*",
        "https://chat.deepseek.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://chat.mistral.ai/*",
        "https://poe.com/*",
        "https://huggingface.co/chat/*",
        "https://aistudio.google.com/*",
        "https://lmarena.ai/*",
        "https://copilot.microsoft.com/*",
        "https://you.com/*",
        "https://pi.ai/*",
        "https://coral.cohere.com/*",
        "https://www.notion.so/*",
        "https://notion.so/*",
        "https://coda.io/*",
        "https://docs.google.com/*",
        "https://linear.app/*",
        "https://clickup.com/*",
        "https://app.clickup.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
