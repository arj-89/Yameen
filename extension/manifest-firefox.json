{
  "manifest_version": 2,
  "name": "يمين — Arabic RTL for AI & Productivity",
  "short_name": "يمين",
  "version": "1.1.0",
  "description": "Arabic RTL for Claude, ChatGPT, Gemini, Grok, DeepSeek, Perplexity, Notion, Coda and more. Zero config — install and read.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": ["storage", "activeTab"],
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://grok.com/*",
        "https://chat.deepseek.com/*",
        "https://*.perplexity.ai/*",
        "https://chat.mistral.ai/*",
        "https://poe.com/*",
        "https://huggingface.co/chat/*",
        "https://aistudio.google.com/*",
        "https://lmarena.ai/*",
        "https://copilot.microsoft.com/*",
        "https://you.com/*",
        "https://pi.ai/*",
        "https://coral.cohere.com/*",
        "https://*.notion.so/*",
        "https://coda.io/*",
        "https://docs.google.com/*",
        "https://linear.app/*",
        "https://*.clickup.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "yameen@arj.dev",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
